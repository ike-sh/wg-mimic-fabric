# 服务端线路示例（占位值，勿用于生产）

PROFILE_ID=my-tunnel
PROFILE_NAME=my-tunnel
ROLE=server
ENABLED=true

WAN_IFACE=eth0
PUBLIC_IP=203.0.113.10
WG_PORT=51820
WG_MTU=1420

WG_IPV4_SUBNET=10.66.66.0/24
WG_SERVER_IPV4=10.66.66.1/32
WG_CLIENT_IPV4=10.66.66.2/32

MIMIC_KEEPALIVE=300:::
MIMIC_XDP_MODE=
FW_OPEN_PORT=true

