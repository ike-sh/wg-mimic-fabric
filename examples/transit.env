# IX / 落地侧线路示例（nat-transit，占位值，勿用于生产）
# 实际配置由 `wm create-transit` 生成于 /etc/wg-mimic-fabric/profiles/<id>.env

PROFILE_ID=ix-nat
PROFILE_NAME=ix-nat
ROLE=nat-transit
ENABLED=true

WAN_IFACE=eth0
WG_MESH_SUBNET=10.88.0.0/24
WG_IX_IP=10.88.0.2
WG_INGRESS_IP=10.88.0.1
WG_PORT=51820
WG_MTU=1420

IX_ENDPOINT_HOST=nat.example      # 公网入口可达的 IX 公网地址（域名或IP，入口连它）
# Mimic 在 IX 侧按本机网卡实际 IP 匹配（自动探测 WAN_IFACE 的全局 IPv4）。
# NAT/多IP 机器若自动探测不对，显式设 MIMIC_LOCAL_IP=<网卡上的真实IP，如内网IP>
# MIMIC_LOCAL_IP=

# 密钥由 wm create-transit 自动生成，勿手填真实私钥到仓库
WG_PRIVATE_KEY=__IX_PRIVATE__
WG_PUBLIC_KEY=__IX_PUBLIC__
WG_PEER_PUBLIC_KEY=__INGRESS_PUBLIC__
INGRESS_PRIVKEY_B64=__INGRESS_PRIV_B64__   # 预生成入口私钥，写入接入码

FORWARD_PROTO=both
# 可选：商家中转端口池（如 40000-40010,40050）。设置后 create-transit/add-rule
# 自动从池分配下一个空闲端口并强制端口∈池；留空=每条规则手动指定中转端口
TRANSIT_PORT_POOL=
MIMIC_KEEPALIVE=300:::
MIMIC_XDP_MODE=
FW_OPEN_PORT=true

# 转发规则存于 profiles/ix-nat/rules/<rule_id>.env，例如 rule-main：
#   RULE_ID=rule-main
#   RULE_NOTE=默认转发
#   RULE_ENABLED=true
#   TRANSIT_PORT=40000
#   LANDING_HOST=1.2.3.4
#   LANDING_PORT=50000
#   FORWARD_PROTO=both
