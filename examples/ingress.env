# 公网入口线路示例（nat-ingress，占位值）
# 实际配置由 `wm import-code` 解析接入码生成于 profiles/<id>-ingress.env

PROFILE_ID=ix-nat-ingress
PROFILE_NAME=ix-nat-ingress
ROLE=nat-ingress
ENABLED=true

WAN_IFACE=eth0
INGRESS_PUBLIC_HOST=198.51.100.7   # 入口公网 IP（客户端连接地址）

WG_MESH_SUBNET=10.88.0.0/24
WG_IX_IP=10.88.0.2
WG_INGRESS_IP=10.88.0.1
WG_PORT=51820
WG_MTU=1420
IX_ENDPOINT_HOST=nat.example

WG_PRIVATE_KEY=__INGRESS_PRIVATE__   # 由接入码解出
WG_PUBLIC_KEY=__INGRESS_PUBLIC__
WG_PEER_PUBLIC_KEY=__IX_PUBLIC__

FORWARD_PROTO=both
MIMIC_KEEPALIVE=300:::
MIMIC_XDP_MODE=native
FW_OPEN_PORT=true

# 规则存于 profiles/ix-nat-ingress/rules/<rule_id>.env，含分配的 CLIENT_PORT：
#   RULE_ID=rule-main
#   TRANSIT_PORT=40000
#   LANDING_HOST=1.2.3.4
#   LANDING_PORT=50000
#   FORWARD_PROTO=both
#   CLIENT_PORT=30000
